generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model categories {
  id                String              @id @default(uuid()) @db.Uuid
  profile_id        String?             @db.Uuid
  name              String              @db.VarChar(100)
  type              String              @db.VarChar(20)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  profiles          profiles?           @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction_items transaction_items[]

  @@unique([profile_id, name, type])
}

model product_categories {
  id         String     @id @default(uuid()) @db.Uuid
  profile_id String?    @db.Uuid
  name       String     @db.VarChar(100)
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  profiles   profiles?  @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products[]

  @@unique([profile_id, name])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment_methods {
  id                String              @id @default(uuid()) @db.Uuid
  profile_id        String?             @db.Uuid
  name              String              @db.VarChar(50)
  is_active         Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  profiles          profiles?           @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction_items transaction_items[]

  @@unique([profile_id, name])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model permissions {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @unique @db.VarChar(100)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id                 String               @id @default(uuid()) @db.Uuid
  role_id            String?              @db.Uuid
  email              String               @unique @db.VarChar(255)
  full_name          String?              @db.VarChar(255)
  business_name      String?              @db.VarChar(255)
  phone_number       String?              @db.VarChar(20)
  address            String?
  avatar_url         String?
  banner_url         String?
  bio                String?
  password           String?              @db.VarChar(255)
  is_active          Boolean?             @default(true)
  metadata           Json?                @default("{}")
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  branch_id          String?              @db.Uuid
  username           String?              @unique @db.VarChar(100)
  payment_qr         String?
  owned_branches     branches[]           @relation("TenantBranches")
  categories         categories[]
  orders             orders[]
  payment_methods    payment_methods[]
  product_categories product_categories[]
  products           products[]
  branches           branches?            @relation("BranchStaff", fields: [branch_id], references: [id], onUpdate: NoAction)
  roles              roles?               @relation(fields: [role_id], references: [id], onUpdate: NoAction)
  transaction_groups transaction_groups[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model roles {
  id               String             @id @default(uuid()) @db.Uuid
  name             String             @unique @db.VarChar(50)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  profiles         profiles[]
  role_permissions role_permissions[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaction_attachments {
  id                 String              @id @default(uuid()) @db.Uuid
  group_id           String?             @db.Uuid
  file_url           String
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  transaction_groups transaction_groups? @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaction_groups {
  id                      String                    @id @default(uuid()) @db.Uuid
  profile_id              String?                   @db.Uuid
  reference_number        String?                   @unique @db.VarChar(100)
  transaction_date        DateTime?                 @default(dbgenerated("CURRENT_DATE")) @db.Date
  total_income            Decimal?                  @default(0) @db.Decimal(15, 2)
  total_expense           Decimal?                  @default(0) @db.Decimal(15, 2)
  net_balance             Decimal?                  @default(0) @db.Decimal(15, 2)
  description             String?
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  branch_id               String?                   @db.Uuid
  customer_name           String?                   @db.VarChar(255)
  customer_phone          String?                   @db.VarChar(20)
  customer_address        String?
  order_status            Int?                      @default(6)
  transaction_attachments transaction_attachments[]
  branches                branches?                 @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  profiles                profiles?                 @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transaction_items       transaction_items[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transaction_items {
  id                 String              @id @default(uuid()) @db.Uuid
  group_id           String?             @db.Uuid
  category_id        String?             @db.Uuid
  payment_method_id  String?             @db.Uuid
  type               String              @db.VarChar(20)
  name               String?             @db.VarChar(255)
  amount             Decimal?            @default(0) @db.Decimal(15, 2)
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  product_id         String?             @db.Uuid
  quantity           Int                 @default(1)
  categories         categories?         @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  transaction_groups transaction_groups? @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payment_methods    payment_methods?    @relation(fields: [payment_method_id], references: [id], onUpdate: NoAction)
  products           products?           @relation(fields: [product_id], references: [id], onUpdate: NoAction)
}

model branches {
  id                   String               @id @default(uuid()) @db.Uuid
  tenant_id            String               @db.Uuid
  name                 String               @db.VarChar(100)
  address              String?
  phone_number         String?              @db.VarChar(20)
  is_active            Boolean?             @default(true)
  created_at           DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?            @default(now()) @db.Timestamptz(6)
  payment_qr           String?
  tenant               profiles             @relation("TenantBranches", fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders               orders[]
  product_stocks       product_stocks[]
  products             products[]           @relation("BranchProducts")
  staff                profiles[]           @relation("BranchStaff")
  stock_mutations_from stock_mutations[]    @relation("FromBranch")
  stock_mutations_to   stock_mutations[]    @relation("ToBranch")
  transaction_groups   transaction_groups[]
}

model products {
  id                 String              @id @default(uuid()) @db.Uuid
  profile_id         String              @db.Uuid
  category_id        String?             @db.Uuid
  name               String              @db.VarChar(255)
  description        String?
  base_price         Decimal             @default(0) @db.Decimal(15, 2)
  sell_price         Decimal             @default(0) @db.Decimal(15, 2)
  image_url          String?
  is_active          Boolean?            @default(true)
  created_at         DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?           @default(now()) @db.Timestamptz(6)
  branch_id          String?             @db.Uuid
  order_items        order_items[]
  product_stocks     product_stocks[]
  branches           branches?           @relation("BranchProducts", fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_categories product_categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  profiles           profiles            @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stock_mutations    stock_mutations[]
  transaction_items  transaction_items[]
}

model product_stocks {
  id         String    @id @default(uuid()) @db.Uuid
  product_id String    @db.Uuid
  branch_id  String    @db.Uuid
  stock      Int       @default(0)
  min_stock  Int       @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  branches   branches  @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, branch_id])
}

model stock_mutations {
  id             String    @id @default(uuid()) @db.Uuid
  product_id     String    @db.Uuid
  from_branch_id String?   @db.Uuid
  to_branch_id   String?   @db.Uuid
  quantity       Int
  type           String    @db.VarChar(50)
  notes          String?
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  from_branch    branches? @relation("FromBranch", fields: [from_branch_id], references: [id], onUpdate: NoAction)
  products       products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  to_branch      branches? @relation("ToBranch", fields: [to_branch_id], references: [id], onUpdate: NoAction)
}

model order_items {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String?   @db.Uuid
  product_id String?   @db.Uuid
  quantity   Int       @default(1)
  price      Decimal   @default(0) @db.Decimal(15, 2)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  orders     orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products? @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id       String?       @db.Uuid
  branch_id        String?       @db.Uuid
  reference_number String        @unique @db.VarChar(100)
  customer_name    String        @db.VarChar(255)
  customer_phone   String        @db.VarChar(20)
  customer_address String?
  payment_method   String        @db.VarChar(50)
  total_price      Decimal       @default(0) @db.Decimal(15, 2)
  status           String        @default("PENDING") @db.VarChar(50)
  created_at       DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?     @default(now()) @db.Timestamptz(6)
  order_items      order_items[]
  branches         branches?     @relation(fields: [branch_id], references: [id], onUpdate: NoAction)
  profiles         profiles?     @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
